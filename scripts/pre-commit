#!/usr/bin/env bash
# Pre-commit hook: block commits if version constants are out of sync
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

./scripts/check-version.sh >/dev/null 2>&1
if [ $? -ne 0 ]; then
  echo ""
  echo "COMMIT BLOCKED: Version constants are out of sync!"
  echo ""
  ./scripts/check-version.sh
  echo ""
  echo "Fix with: npm run bump-version <version>"
  echo ""
  exit 1
fi
